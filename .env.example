 # ==========================================
 # HPMS - 家庭采购决策系统 环境变量配置
 # ==========================================
 # 复制此文件为 .env 并按需修改配置
 # cp .env.example .env
 
 # --- 应用配置 ---
 APP_NAME=HPMS - Family Shopping Decision System
 DEBUG=false
 SECRET_KEY=change-me-to-a-random-secret-key-in-production
 
 # --- MySQL 数据库 ---
 MYSQL_ROOT_PASSWORD=root_password
 MYSQL_HOST=mysql
 MYSQL_PORT=3306
 MYSQL_USER=hpms
 MYSQL_PASSWORD=hpms_password
 MYSQL_DATABASE=hpms
 
 # --- Redis ---
 REDIS_HOST=redis
 REDIS_PORT=6379
 REDIS_DB=0
 REDIS_PASSWORD=
 
 # --- Meilisearch 搜索 ---
 MEILISEARCH_HOST=http://meilisearch:7700
 MEILISEARCH_API_KEY=hpms_master_key
 MEILISEARCH_INDEX=products
 
 # --- 阿里云 OSS（可选，留空使用Mock） ---
 OSS_ACCESS_KEY_ID=
 OSS_ACCESS_KEY_SECRET=
 OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
 OSS_BUCKET_NAME=hpms-files
 
 # --- 阿里云 OCR（可选，留空使用Mock） ---
 OCR_ACCESS_KEY_ID=
 OCR_ACCESS_KEY_SECRET=
 OCR_ENDPOINT=ocr.cn-hangzhou.aliyuncs.com
 
 # --- Celery 异步任务 ---
 CELERY_BEAT_SCHEDULE_ENABLED=true
 PRICE_SCRAPE_INTERVAL_HOURS=4
 PRICE_SCRAPE_HOURS=9,13,18,23
 
 # --- CORS（开发时添加前端地址） ---
 CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost
 
 # --- 日志 ---
 LOG_LEVEL=INFO
